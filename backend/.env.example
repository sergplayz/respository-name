# Set these on Render (Environment) or copy to `.env` for local runs.
#
# Required:
MATCOM_ADMIN_USERNAME=milda107
MATCOM_JWT_SECRET=replace-with-at-least-16-random-characters
#
# Password — use ONE of:
# (A) Plain text (fine if only in Render “Secret” / not in git):
MATCOM_ADMIN_PASSWORD=riblix
#
# (B) Or bcrypt hash instead of plain (then omit MATCOM_ADMIN_PASSWORD):
# MATCOM_ADMIN_PASSWORD_BCRYPT=$2b$12$7jCESg.rA06/mtS/qM7oWu82oBrK0QdkdGxF0KRk0CNSleQPKyJUS
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOURPASS', bcrypt.gensalt()).decode())"
